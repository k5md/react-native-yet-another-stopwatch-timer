{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "noImplicitAny": false,
    "strict": false,
    "moduleResolution": "node16",
    "module": "node16",
    "jsx": "react-native",
    "target": "ESNext",
    "skipLibCheck": true,
    "paths": {
      "react-native-yet-another-stopwatch-timer": [ "./index.d.ts" ]
    },
    "types": [ "jest", "node" ],
    "resolveJsonModule": true,
    "esModuleInterop": true,
  },
  "include": [
    "src/**/*.js",
    "src/**/*.jsx",
    "index.d.ts",
    "example/**/*.js",
    "example/**/*.jsx"
  ]
}