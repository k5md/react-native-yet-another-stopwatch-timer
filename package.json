    "react-native": "^0.84.1",
    "react-native-reanimated": "^4.3.0",
    "react-native-worklets": "^0.8.1",
    "rimraf": "^6.1.3",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^6.0.3"
  }
